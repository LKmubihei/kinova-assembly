  <xacro:macro name="h1_robot_urdf_config" params="if_add_external_device">
    <xacro:if value="${if_add_external_device}">
      <xacro:include filename="$(find inspire_hand_description)/urdf/inspire_hand.urdf.xacro"/>
      <xacro:include filename="$(find robotiq_gripper_description)/urdf/robotiq_gripper.urdf.xacro"/>

      <joint name="gripper_connect_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <!-- <origin xyz="0 0 0.00695" rpy="0 0 0" /> -->
        <parent link="link-L7"/>
        <child link="hand_e_link"/>
      </joint>

      <joint name="hand_connect_joint" type="fixed">
        <!-- <origin xyz="0 0 0" rpy="-1.57 0 -1.57" /> -->
        <origin xyz="0 0 0" rpy="-1.57 0 1.57" />
        <parent link="link-R7"/>
        <child link="R_hand_base_link"/>
      </joint>
    </xacro:if>
  </xacro:macro>

  <xacro:macro name="gazebo_urdf_config" params="sim_gazebo_classic">
    <xacro:if value="${sim_gazebo_classic}">
      <link name="world"/>
      <joint name="fixed" type="fixed">
        <parent link="world"/>
        <child link="fake_link"/>
      </joint>
    </xacro:if>
  </xacro:macro>

</robot>