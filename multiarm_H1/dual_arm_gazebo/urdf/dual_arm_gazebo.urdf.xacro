  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find dual_arm_gazebo)/config/dual_arm_control.yaml</parameters>
    </plugin>
  </gazebo>

  <ros2_control name="dual_arm" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <xacro:macro name ="joint_interface" params="Joint_Name initial_pos">
      <joint name="${Joint_Name}">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">${initial_pos}</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
    </xacro:macro>

    <xacro:joint_interface Joint_Name="J1" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="Body" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J1" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J2" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J3" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J4" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J5" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J6" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="L-J7" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J1" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J2" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J3" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J4" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J5" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J6" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="R-J7" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="H-J1" initial_pos="0.0"/>
    <xacro:joint_interface Joint_Name="H-J2" initial_pos="0.0"/>
  </ros2_control>

  <xacro:macro name ="link_reference" params="link_name material_">
    <gazebo reference="${link_name}">
      <material>${material_}</material>
    </gazebo>
  </xacro:macro>

  <xacro:link_reference link_name="base_link" material_= "Gazebo/DarkGrey"/>
  <xacro:link_reference link_name="link-J1" material_= "Gazebo/Orange"/>
