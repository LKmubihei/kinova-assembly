<?xml version="1.0" encoding="utf-8"?>
<robot name = "robotiq_gripper" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name = "pkg_address" value = "file://$(find robotiq_gripper_description)"/>
  <!-- <link name="base_footprint">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
            <box size="0.001 0.001 0.001" />
        </geometry>
    </visual>
  </link>
  <joint name="arm_to_hand_e" type="fixed">
    <origin xyz="0 0 0.00695" rpy="0 0 0" />
    <parent link="base_footprint"/>
    <child link="hand_e_link"/>
  </joint> -->
   <link name="hand_e_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.04607"/>
      <mass value="0.86387"/>
      <inertia ixx="1017560E-9" ixy="0" ixz="2235E-9" iyy="1028041E-9" iyz="0" izz="489810E-9"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_address}/meshes/visual/hand-e.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="Dark">
        <color rgba=".1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_address}/meshes/visual/hand-e.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>
  <link name="hande_left_finger">
    <inertial>
      <origin rpy="0 0 0" xyz="0.02262 -0.00759 0.00738"/>
      <mass value="0.03804"/>
      <inertia ixx="13567E-9" ixy="1849E-9" ixz="3622E-9" iyy="15784E-9" iyz="3616E-9" izz="7478E-9"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_address}/meshes/visual/finger_1.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="DarkGray">
        <color rgba=".4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_address}/meshes/visual/finger_1.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>
  <link name="hande_right_finger">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.02262 0.00759 0.00738"/>
      <mass value="0.03804"/>
      <inertia ixx="13567E-9" ixy="1849E-9" ixz="-3622E-9" iyy="15784E-9" iyz="-3616E-9" izz="7478E-9"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_address}/meshes/visual/finger_2.dae" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="DarkGray">
        <color rgba=".4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_address}/meshes/visual/finger_2.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>
  <joint name="gripper_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0.099"/>
    <parent link="hand_e_link"/>
    <child link="hande_left_finger"/>
    <axis xyz="-1 0 0"/>
    <limit effort="130" lower="0" upper="0.025" velocity="0.15"/>
  </joint>
  <joint name="hande_right_finger_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0.099"/>
    <parent link="hand_e_link"/>
    <child link="hande_right_finger"/>
    <axis xyz="1 0 0"/>
    <limit effort="130" lower="0" upper="0.025" velocity="0.15"/>
    <mimic joint="gripper_joint" multiplier="1" offset="0"/>
  </joint>
</robot>
